# --- Global Visuals ---
sort=-time
layer=overlay
background-color=#1a1b26
text-color=#c0caf5
width=350
height=150
border-size=2
border-color=#bb9af7
border-radius=6
font=JetBrainsMono Nerd Font 10

# --- Layout ---
margin=5
anchor=top-center
padding=15
icons=1
max-icon-size=48
# Moves icon to left, text to right
icon-location=left 
markup=1
format=<b>%s</b>\n%b

# --- Behavior ---
default-timeout=5000
ignore-timeout=0
# Grouping stops spam from taking over screen
max-visible=5

# --- Input ---
on-button-left=invoke-default-action
on-button-right=dismiss

# --- CRITERIA BLOCKS (Overrides) ---

# 1. Critical Urgency: Red border, never disappears automatically
[urgency=critical]
border-color=#f7768e
default-timeout=0

# 2. Low Urgency: Dim border, disappears fast (2s)
[urgency=low]
border-color=#414868
default-timeout=2000

# 3. Screenshot Tool (Grim/Slurp usually send as 'grim')
# Don't group these, I want to see every screenshot confirmation
[app-name="grim"]
group-by=none

# 4. Volume/Brightness (Osd)
# Make these small and disappear instantly
[category="osd"]
default-timeout=1000
border-radius=20

[mode=dnd]
invisible=1
