[user]
	name = jayshozie
	email = jayshozie@gmail.com
	signingkey = 813E5F0FB80AA0D1
[credential "https://github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential
[init]
	defaultBranch = main
[core]
	editor = nvim
	excludefile = /home/jaysh/.gitignore
[alias]
	pr = pull --rebase
    ss = status -s
    stag = tag -s
[commit]
	gpgsign = true
[tag]
    gpgSign = true
