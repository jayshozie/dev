#!/usr/bin/env bash

# ----------------------- #
#  1. Idempotency Helper  #
# ----------------------- #
path_prepend() {
    if [ -d "$1" ] && [[ ":$PATH:" != *":$1:"* ]]; then
        export PATH="$1:$PATH"
    fi
}

# -------------------------- #
#  2. Environment Variables  #
# -------------------------- #
export CLONES_DIR="$HOME/src"
export XDG_CONFIG_HOME="$HOME/.config"
export MOZ_ENABLE_WAYLAND=1
# export DISPLAY=:1 # uncomment if needed

# Editors & Pagers
export EDITOR=nvim
export SYSTEMD_EDITOR=nvim
export VISUAL=nvim
export MANPAGER='nvim +Man!'
export CLONES_DIR=$HOME/src
export GEMINI_SYSTEM_MD='~/.gemini/system.md'

# -------------------- #
#  3. Path Management  #
# -------------------- #
# NVM (Node Version Manager)
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"

# Bun
export BUN_INSTALL="$HOME/.bun"
path_prepend "$BUN_INSTALL/bin"

# Ruby Gems
export GEM_HOME="$HOME/gems"
path_prepend "$GEM_HOME/bin"

# Cargo
path_prepend "${HOME}/.cargo/bin"

# Local Scripts (Weather, Tmux, etc.)
path_prepend "$HOME/.local/bin/scripts/weather"
path_prepend "$HOME/.local/bin/scripts/tmux-sessionizer"
path_prepend "$HOME/.local/bin/scripts"

# .local/bin
path_prepend "$HOME/.local/bin"

# -------------- #
#  4. Linuxbrew  #
# -------------- #
if [[ ":$PATH:" != *":/home/linuxbrew/.linuxbrew/bin:"* ]]; then
    eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi

# ----------------------------------- #
#  5. Interactive Shell Integrations  #
# ----------------------------------- #
export STARSHIP_CONFIG="$XDG_CONFIG_HOME/starship/starship.toml"
eval "$(starship init bash)"
