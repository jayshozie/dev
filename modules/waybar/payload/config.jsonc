{
    "layer": "top",
    "position": "top",
    "height": 34,
    "spacing": 0,
    "modules-left": ["hyprland/workspaces", "custom/mpris"],
    "modules-center": ["clock"],
    "modules-right": ["custom/rec", "custom/rss", "wireplumber", "custom/net", "bluetooth", "battery"],

    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "format": "{name}",
        "on-click": "activate"
    },

    /* OLD CLOCK BLOCK
    "clock": {
        "format": "{:%H:%M  |  %b %d, %a}",
        "tooltip-format": "<big>{:%B} {ordinal_date}</big>\n\n<span font='JetBrainsMono Nerd Font ExtraLight' size='12000'>{calendar}</span>",
        "calendar": {
            "mode": "month",
            "mode-mon-col": 3,
            "on-scroll": 1,
            "format": {
                "months":     "<span color='#bb9af7'><b>{}</b></span>", // Purple header
                "days":       "<span color='#787c99'>{}</span>",       // Dimmed standard days
                "weeks":      "<span color='#7dcfff'><b>W{}</b></span>", // Cyan week numbers
                "weekdays":   "<span color='#ff9e64'><b>{}</b></span>", // Orange Mon/Tue/Wed...
                "today":      "<span color='#7aa2f7'><b><u>{}</u></b></span>" // Bright Blue & Underlined for Today
            }
        },
    },
    */

    "clock": {
        "format": "󰣇  {:%H:%M}",
        "tooltip-format": "<tt>{calendar}</tt>",
        "calendar": {
            "mode"          : "year",
            "mode-mon-col"  : 3,
            "weeks-pos"     : "right",
            "on-scroll"     : 1,
            "format": {
                "months":     "<span color='#c0caf5'><b>{}</b></span>",
                "days":       "<span color='#c0caf5'>{}</span>",
                "weeks":      "<span color='#7dcfff'><b>W{}</b></span>",
                "weekdays":   "<span color='#ff9e64'><b>{}</b></span>",
                "today":      "<span color='#f7768e'><b><u>{}</u></b></span>"
            }
        },
        "actions": {
            "on-click": "shift_up",
            "on-click-right": "shift_down",
            "on-click-middle": "mode",
        }
    },

    "custom/mpris": {
        "format": "{}",
        "exec": "/home/jaysh/.local/bin/scripts/waybar-mpris.sh",
        "return-type": "json",
        "on-click": "playerctl --player=spotify play-pause", 
        "on-click-right": "playerctl --player=spotify next",
        "on-click-middle": "playerctl --player=spotify previous"
    },

    "custom/rec": {
        "format": "{}",
        "exec": "/home/jaysh/.local/bin/scripts/waybar-rec.sh",
        "return-type": "json",
        "on-click": "/home/jaysh/.local/bin/scripts/waybar-rec.sh toggle",
        "restart-interval": 1
    },

    "custom/rss": {
        "format": "󰑫 {}",
        "exec": "/home/jaysh/.local/bin/scripts/waybar-rss.sh",
        "return-type": "json",
        "interval": 5,
        "on-click": "alacritty -e bulletty"
    },

    "custom/net": {
        "format": "{}",
        "exec": "/home/jaysh/.local/bin/scripts/waybar-net.sh",
        "return-type": "json",
        "inteval": 1,
    },

    "wireplumber": {
        "format": "{icon}  {node_name} {volume}%",
        "format-muted": "  Muted",
        "format-icons": ["", "", ""],
        "on-click": "pavucontrol"
    },

    "bluetooth": {
        "format": "",
        "format-connected": " {device_alias}",
        "format-connected-battery": " {device_alias} {device_battery_percentage}%",
        "tooltip-format": "{controller_alias}\t{controller_address}",
        "tooltip-format-connected": "Host:\n{controller_alias}\t{controller_address}\n\nConnected Devices: {num_connections}\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
        /* That doesn't work for some reason, crashes waybar. Need to check. */
        /* "format-icons": ["", "", "", "", ""] */
        "on-click": "alacritty -e bluetoothctl",
        "on-click-middle": "bluetoothctl power off",
        "on-click-right": "bluetoothctl power on",
    },

    "battery": {
        "states": {
            "warning": 30,
            "critical": 15,
        },
        "format": "{icon}  {capacity}%",
        "format-charging": "󱐥 {capacity}%",
        "format-icons": ["", "", "", "", ""]
    },
}
