#!/usr/bin/env bash

sudo systemctl start --now via-vpn-srv.service via-vpn.service

via-cli session info 2>/dev/null | grep -q "active" || via-cli session start 2>/dev/null

if via-cli vpn status 2>/dev/null | grep -iq "not connected"; then

    via-cli vpn connect --username e267561@metu.edu.tr --userpass "$(pass metu)" > /dev/null 2>&1

    if [[ $? -eq 0 ]]; then
        notify-send "VPN" "Connected to METU"
    else
        notify-send "VPN" "Connection Failed"
    fi
else
    via-cli vpn disconnect > /dev/null 2>&1

    # mask it first so it CANNOT restart even if it wants to
    sudo systemctl mask via-vpn-srv.service via-vpn.service
    # kill them hard
    sudo systemctl kill -s SIGKILL via-vpn-srv.service via-vpn.service
    # reset the "failed" state so systemd doesn't keep tracking them
    sudo systemctl reset-failed via-vpn-srv.service via-vpn.service
    # unmask for next time (optional, or just unmask in the 'start' section)
    sudo systemctl unmask via-vpn-srv.service via-vpn.service

    notify-send "VPN" "Disconnected from METU"
fi
