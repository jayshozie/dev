FROM ubuntu:24.04

RUN apt-get update && apt-get install -y \
    sudo \
    build-essential \
    git \
    vim \
    && rm -rf /var/lib/apt/lists/*

RUN useradd -ms /bin/bash jaysh && \
    echo "jaysh:0000" | chpasswd && \
    usermod -aG sudo jaysh

USER jaysh

WORKDIR /home/jaysh

ARG CACHE_DATE=noncacheable
RUN git clone https://github.com/jayshozie/dotfiles.git

WORKDIR /home/jaysh/dotfiles

RUN git checkout dev
